{
    "makefile.makefilePath": "${workspaceFolder}/arwin/code/Makefile",
    "vim.normalModeKeyBindingsNonRecursive": [
    {
        "before": ["="],
        "after": ["g", "q"]   // or leave empty if you just want to free the key
    }
    ],

    "vim.visualModeKeyBindingsNonRecursive": [
        {
            "before": ["="],
            "commands": ["editor.action.formatSelection"]
        }
    ],
    "vim.statusBarColorControl": true,
    "vim.handleKeys": {
        "<C-a>": false,
        "<C-w>": false,
        "=": true
    },
    "clangd.arguments": [
        "--background-index",
        "--clang-tidy",
        "--header-insertion=iwyu"
    ],
    "cmake.ignoreCMakeListsMissing": true
}