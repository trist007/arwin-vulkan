{
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Debug (Windows - MSVC)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/arwin/bin/main.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/arwin/bin",
            "environment": [],
            "console": "integratedTerminal",
            "showDisplayString": true
        },
        {
            // New Linux configuration using GDB
            "name": "Debug (Linux - GDB)",
            //"type": "cppdbg",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/arwin/bin/arwin",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/arwin/bin",
            "environment": [],
            "console": "integratedTerminal",

            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",

            "setupCommands": [
                {
                    "description": "Enable pretty-printing for STL, glm, etc.",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],

            "preLaunchTask": "make"
        }
    ]
}